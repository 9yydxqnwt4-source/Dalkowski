    for _, col in ipairs(cols) do
        local d = new("Frame", {
            Size = UDim2.new(1, 0, 0, 8), BackgroundTransparency = 1,
            LayoutOrder = order, ZIndex = 2,
        }, col)
        new("Frame", {
            AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 4, 0.5, 0),
