function Tab:CreateToggle(opts)
    opts = mergeDefaults(opts, "Toggle")
    local win = self._window
    local state = opts.CurrentValue or false
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local card = makeCard(self, 58)
    attachHover(card)
    bindTooltip(card, opts.Tooltip)
    makeIconSquare(card, 28, opts.Icon)
    makeCardLabels(card, opts.Name or "Toggle", opts.Description, 120)
    local w, h = 42, 24
    local knobSize = h - 6
    local track = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(w, h), BackgroundColor3 = COLOR.BgLight,
        BorderSizePixel = 0, ZIndex = 3,
    }, card)
    corner(track, math.floor(h/2))
    local trackStroke = stroke(track, Color3.fromRGB(255,255,255), wA(0.1), 1)
    local knob = new("Frame", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 2, 0.5, 0),
        Size = UDim2.fromOffset(knobSize, knobSize),
        BackgroundColor3 = Color3.fromRGB(255,255,255), BorderSizePixel = 0, ZIndex = 4,
    }, track)
    corner(knob, math.floor(knobSize/2))
    local function apply(s, anim)
        state = s
        local d = anim and 0.2 or 0
        if s then
            tween(track, d, { BackgroundColor3 = COLOR.Accent, BackgroundTransparency = 0 })
            tween(trackStroke, d, { Transparency = 1 })
            tween(knob, d, {
                Position = UDim2.new(1, -(knobSize + 3), 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255,255,255), BackgroundTransparency = 0,
            }, Enum.EasingStyle.Quart)
        else
            tween(track, d, { BackgroundColor3 = COLOR.BgLight, BackgroundTransparency = 0 })
            tween(trackStroke, d, { Transparency = wA(0.14) })
            tween(knob, d, {
                Position = UDim2.new(0, 3, 0.5, 0),
                BackgroundColor3 = Color3.fromRGB(255,255,255),
                BackgroundTransparency = wA(0.5),
            }, Enum.EasingStyle.Quart)
        end
    end
    apply(state, false)
    local hit = new("TextButton", {
        Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1,
        Text = "", AutoButtonColor = false, ZIndex = 5,
    }, card)
    hit.MouseButton1Click:Connect(function()
        state = not state
        apply(state, true)
        updateFlag(win, flag, state)
        pcall(cb, state)
    end)
    local element = {
        Type = "Toggle", Value = state,
        Set = function(self2, v)
            state = v and true or false; self2.Value = state
            apply(state, true); updateFlag(win, flag, state); pcall(cb, state)
        end,
        Get = function() return state end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

