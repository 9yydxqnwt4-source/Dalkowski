local function _isMobileDevice()
    return UserInputService.TouchEnabled and not UserInputService.MouseEnabled
end

local function _computeUIScale(viewport)
    local w, h = viewport.X, viewport.Y
    local cap = _isMobileDevice() and 1.0 or 1.1
    -- guarantee the 860x580 window always fits inside the viewport (with a small margin)
    local fit = math.min((w - 40) / 1000, (h - 40) / 580)
    return math.max(0.4, math.min(cap, fit))
end

local _scaledGuis = {}
setmetatable(_scaledGuis, { __mode = "k" })

local function applyResponsiveScale(screenGui)
    if not screenGui then return end
    local uiScale = screenGui:FindFirstChildOfClass("UIScale")
    if not uiScale then
        uiScale = Instance.new("UIScale")
        uiScale.Parent = screenGui
    end
    local function update()
        local w, h = screenGui.AbsoluteSize.X, screenGui.AbsoluteSize.Y
        if w < 2 or h < 2 then
            local cam = workspace.CurrentCamera
            if cam then
                local ok, vp = pcall(function() return cam.ViewportSize end)
                if ok and vp then w, h = vp.X, vp.Y end
            end
        end
        if w >= 2 and h >= 2 then
            local us = uiScale:GetAttribute("UserScale")
            if us then
                local fitCeil = math.min((w - 40) / 1000, (h - 40) / 580)
                uiScale.Scale = math.clamp(us, 0.4, math.max(0.4, fitCeil))
            else
                uiScale.Scale = _computeUIScale(Vector2.new(w, h))
            end
        end
    end
    update()
    _scaledGuis[uiScale] = true
    screenGui:GetPropertyChangedSignal("AbsoluteSize"):Connect(update)
    local function rebind()
        local cam = workspace.CurrentCamera
        if cam then cam:GetPropertyChangedSignal("ViewportSize"):Connect(update) end
        update()
    end
    rebind()
    workspace:GetPropertyChangedSignal("CurrentCamera"):Connect(rebind)
    task.spawn(function()
        local t = 0
        while t < 1.5 do
            update()
            if screenGui.AbsoluteSize.X >= 2 then break end
            t = t + RunService.Heartbeat:Wait()
        end
        update()
    end)
    return uiScale
end

