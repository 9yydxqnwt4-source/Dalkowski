function Window:SetLogo(value)
    if not self._logoBox then return end
    local isIcon = type(value) == "string" and (#value > 1 or value:match("^%d+$") or value:sub(1,4) == "http" or value:sub(1,8) == "rbxasset")
    if isIcon or type(value) == "number" then
        if self._logoLabel then self._logoLabel:Destroy(); self._logoLabel = nil end
        if self._logoImg then self._logoImg:Destroy(); self._logoImg = nil end
        self._logoImg = applyIcon(self._logoBox, value, 34, 0.95)
        self.LogoIcon = value
    else
        if self._logoImg then self._logoImg:Destroy(); self._logoImg = nil end
        self.LogoText = tostring(value or "")
        if self._logoLabel then
            self._logoLabel.Text = self.LogoText
        else
            self._logoLabel = new("TextLabel", {
                Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = self.LogoText,
                Font = Enum.Font.GothamBold, TextSize = 12, TextColor3 = COLOR.TextPrimary, ZIndex = 4,
            }, self._logoBox)
        end
    end
end

local function isLightTheme()
    local bg = COLOR.BgDeep
    return (bg.R + bg.G + bg.B) / 3 > 0.5
end

function Window:_updateGlowForTheme()
    if not self._glow or not self._darkLayer then return end
    local light = isLightTheme()
    self._glow.Visible = not light
    self._darkLayer.Visible = not light
end

function Window:SetAccent(c)
    if typeof(c) ~= "Color3" then return end
    local old = COLOR.Accent
    COLOR.Accent = c
    if self.Gui then
        for _, d in ipairs(self.Gui:GetDescendants()) do
            if d:IsA("GuiObject") and colorEq(d.BackgroundColor3, old) then d.BackgroundColor3 = c end
            if (d:IsA("ImageLabel") or d:IsA("ImageButton")) and colorEq(d.ImageColor3, old) then d.ImageColor3 = c end
            if (d:IsA("TextLabel") or d:IsA("TextButton") or d:IsA("TextBox")) and colorEq(d.TextColor3, old) then d.TextColor3 = c end
            if d:IsA("UIStroke") and colorEq(d.Color, old) then d.Color = c end
        end
    end
    if self._winGrad then
        local h, sat, val = c:ToHSV()
        self._winGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, c),
            ColorSequenceKeypoint.new(0.5, lighten(c, 0.12)),
            ColorSequenceKeypoint.new(1, c),
        })
    end
    if self._glowHalo then self._glowHalo.ImageColor3 = c end
end

function Window:SetBackgroundColor(c)
    if typeof(c) ~= "Color3" then return end
    local oldDeep, oldLight = COLOR.BgDeep, COLOR.BgLight
    local newDeep, newLight = c, lighten(c, 0.04)
    COLOR.BgDeep, COLOR.BgLight = newDeep, newLight
    if self.Window then self.Window.BackgroundColor3 = newDeep end
    if self.Gui then
        for _, d in ipairs(self.Gui:GetDescendants()) do
            if d:IsA("GuiObject") then
                if colorEq(d.BackgroundColor3, oldDeep) then d.BackgroundColor3 = newDeep
                elseif colorEq(d.BackgroundColor3, oldLight) then d.BackgroundColor3 = newLight end
            end
        end
    end
    if self._bgGrad then
        self._bgGrad.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, lighten(c, 0.05)),
            ColorSequenceKeypoint.new(0.5, lighten(c, 0.02)),
            ColorSequenceKeypoint.new(1, c),
        })
    end
end

function Window:GetAccent() return COLOR.Accent end
function Window:GetBackgroundColor() return COLOR.BgDeep end

function Window:ModifyTheme(name)
    local newTheme
    if type(name) == "string" and THEMES[name] then
        newTheme = THEMES[name]
    elseif type(name) == "table" then
        newTheme = name
    else return end
    for k, v in pairs(newTheme) do COLOR[k] = v end
    self.Window.BackgroundColor3 = COLOR.BgDeep
    self:_updateGlowForTheme()
    local light = isLightTheme()
    for _, d in ipairs(self.Gui:GetDescendants()) do
        if d:IsA("TextLabel") or d:IsA("TextBox") then
            if d.TextColor3 == Color3.fromRGB(255,255,255) or d.TextColor3 == Color3.fromRGB(0,0,0)
                or d.TextColor3 == Color3.fromRGB(20,20,22) then
                d.TextColor3 = COLOR.TextPrimary
            end
        end
    end
end

function Window:_loadAvatar(userId)
    if not self._avatar then return end
    self._avatar.ImageTransparency = 1
    task.spawn(function()
        local ok, content = pcall(function()
            return Players:GetUserThumbnailAsync(userId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size60x60)
        end)
        if ok and content and self._avatar then
            self._avatar.Image = content
            tween(self._avatar, 0.3, { ImageTransparency = 0 })
        end
    end)
end

function Window:SetAvatarUserId(userId)
    userId = tonumber(userId)
    if not userId then return end
    self._anon = false
    if self._avatarBox then self._avatarBox.BackgroundColor3 = COLOR.BgDeep end
    self:_loadAvatar(userId)
    task.spawn(function()
        local ok, name = pcall(function() return Players:GetNameFromUserIdAsync(userId) end)
        if ok and name then
            if self._nameLbl then self._nameLbl.Text = name end
            if self._userLbl then self._userLbl.Text = "@" .. name end
        end
    end)
end

function Window:SetAnonymous(state)
    self._anon = state and true or false
    if not self._avatar then return end
    if self._anon then
        self._avatar.Image = ""
        self._avatar.ImageTransparency = 1
        if self._avatarBox then self._avatarBox.BackgroundColor3 = Color3.fromRGB(58, 58, 64) end
        if self._nameLbl then self._nameLbl.Text = "Anonymous" end
        if self._userLbl then self._userLbl.Text = "@hidden" end
    else
        if self._avatarBox then self._avatarBox.BackgroundColor3 = COLOR.BgDeep end
        if self._nameLbl then self._nameLbl.Text = LocalPlayer.DisplayName or "Player" end
        if self._userLbl then self._userLbl.Text = "@" .. (LocalPlayer.Name or "user") end
        self:_loadAvatar(LocalPlayer.UserId)
    end
end

function Window:SetBackground(image, dim)
    if not self.Window then return end
    local holder = self.Window:FindFirstChild("BgImage")
    if not image or image == "" or image == 0 then
        if holder then holder.Visible = false end
        return
    end
    if not holder then
        holder = new("Frame", {
            Name = "BgImage", Size = UDim2.fromScale(1, 1),
            BackgroundTransparency = 1, ClipsDescendants = true, ZIndex = 0,
        }, self.Window)
        corner(holder, 14)
        local img = new("ImageLabel", {
            Name = "Img", AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.fromScale(0.5, 0.5), Size = UDim2.fromScale(1.1, 1.1),
            BackgroundTransparency = 1, ScaleType = Enum.ScaleType.Crop, ZIndex = 1,
        }, holder)
        local d = new("Frame", {
            Name = "Dim", Size = UDim2.fromScale(1, 1),
            BackgroundColor3 = COLOR.BgDeep, BorderSizePixel = 0, ZIndex = 2,
        }, holder)
        self._bgImg = img
        self._bgDim = d
        task.spawn(function()
            while img and img.Parent do
                tween(img, 7, { Size = UDim2.fromScale(1.2, 1.2) }, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                task.wait(7)
                if not img or not img.Parent then break end
                tween(img, 7, { Size = UDim2.fromScale(1.1, 1.1) }, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut)
                task.wait(7)
            end
        end)
    end
    holder.Visible = true
    self._bgImg.Image = (type(image) == "number") and ("rbxassetid://" .. image) or tostring(image)
    self._bgDim.BackgroundTransparency = dim or 0.4
end

function Window:_closeSearch()
    if not self._searchFrame or not self._searchFrame.Visible then return end
    local f = self._searchFrame
    if self._searchBox then self._searchBox.Text = "" end
    local mainTween = tween(f, 0.18, { BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 22) }, Enum.EasingStyle.Quart)
    if self._searchStroke then tween(self._searchStroke, 0.18, { Transparency = 1 }) end
    if self._searchBox then tween(self._searchBox, 0.18, { TextTransparency = 1 }) end
    for _, d in ipairs(f:GetDescendants()) do
        if d:IsA("ImageLabel") then tween(d, 0.18, { ImageTransparency = 1 }) end
    end
    mainTween.Completed:Connect(function() if f then f.Visible = false end end)
    if self.SectionTitle then
        self.SectionTitle.Visible = true
        self.SectionTitle.TextTransparency = 1
        tween(self.SectionTitle, 0.2, { TextTransparency = 0 })
    end
    if self.ActiveTab then
        for _, container in ipairs(self.ActiveTab._cols or { self.ActiveTab.Panel }) do
            for _, el in ipairs(container:GetChildren()) do
                if el:IsA("GuiObject") and not el:IsA("UIListLayout") then el.Visible = true end
            end
        end
    end
end

function Window:_toggleSearch()
    if self._searchFrame and self._searchFrame.Visible then
        self:_closeSearch()
        return
    end
    if not self._searchFrame then
        local f = new("Frame", {
            Name = "SearchBar",
            Position = UDim2.fromOffset(0, 0),
            Size = UDim2.new(1, 0, 0, 26),
            BackgroundColor3 = Color3.fromRGB(255,255,255),
            BackgroundTransparency = 1,
            BorderSizePixel = 0, ZIndex = 20, Visible = false,
        }, self.Content)
        corner(f, 6)
        local fStroke = stroke(f, Color3.fromRGB(255,255,255), 1, 1)
        local searchIcon = new("Frame", {
            AnchorPoint = Vector2.new(0, 0.5),
            Position = UDim2.new(0, 10, 0.5, 0),
            Size = UDim2.fromOffset(14, 14), BackgroundTransparency = 1, ZIndex = 21,
        }, f)
        applyIcon(searchIcon, "search", 14, 0.55)
        local box = new("TextBox", {
            Position = UDim2.fromOffset(30, 0), Size = UDim2.new(1, -40, 1, 0),
            BackgroundTransparency = 1, Text = "", TextTransparency = 1,
            PlaceholderText = "Search...", PlaceholderColor3 = Color3.fromRGB(140,140,140),
            Font = Enum.Font.Gotham, TextSize = 11, TextColor3 = COLOR.TextPrimary,
            TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false, ZIndex = 21,
        }, f)
        self._searchFrame = f
        self._searchBox = box
        self._searchStroke = fStroke
        box:GetPropertyChangedSignal("Text"):Connect(function()
            local q = string.lower(box.Text)
            local tab = self.ActiveTab
            if not tab then return end
            for _, container in ipairs(tab._cols or { tab.Panel }) do
                for _, el in ipairs(container:GetChildren()) do
                    if el:IsA("GuiObject") and not el:IsA("UIListLayout") then
                        if q == "" then el.Visible = true else
                            local found = false
                            for _, d in ipairs(el:GetDescendants()) do
                                if (d:IsA("TextLabel") or d:IsA("TextButton")) and d.Text ~= "" then
                                    if string.lower(d.Text):find(q, 1, true) then found = true; break end
                                end
                            end
                            el.Visible = found
                        end
                    end
                end
            end
        end)
        box.FocusLost:Connect(function(enter)
            if enter and box.Text == "" then self:_closeSearch() end
        end)
    end
    local f = self._searchFrame
    if self.SectionTitle then
        tween(self.SectionTitle, 0.15, { TextTransparency = 1 })
        task.delay(0.15, function()
            if self._searchFrame and self._searchFrame.Visible then
                self.SectionTitle.Visible = false
            end
        end)
    end
    f.Position = UDim2.fromOffset(0, self._statusReservedHeight > 0 and 56 or 0)
    f.Visible = true
    f.BackgroundTransparency = 1
    f.Size = UDim2.new(1, 0, 0, 22)
    self._searchStroke.Transparency = 1
    self._searchBox.TextTransparency = 1
    for _, d in ipairs(f:GetDescendants()) do
        if d:IsA("ImageLabel") then d.ImageTransparency = 1 end
    end
    tween(f, 0.25, { BackgroundTransparency = wA(0.05), Size = UDim2.new(1, 0, 0, 26) }, Enum.EasingStyle.Quart)
    tween(self._searchStroke, 0.25, { Transparency = wA(0.1) })
    tween(self._searchBox, 0.25, { TextTransparency = 0 })
    for _, d in ipairs(f:GetDescendants()) do
        if d:IsA("ImageLabel") then tween(d, 0.25, { ImageTransparency = wA(0.55) }) end
    end
    task.wait(0.05)
    self._searchBox:CaptureFocus()
end

function Window:_applyUIScale(pct, fromSlider)
    if not self._uiScale then return end
    local base = self._uiScaleBase or 1
    if base <= 0 then base = 1 end
    local sc = pct / 100 * base
    local g = self.Gui and self.Gui.AbsoluteSize
    if g and g.X > 2 and g.Y > 2 then
        local fitCeil = math.min((g.X - 40) / 1000, (g.Y - 40) / 580)
        sc = math.clamp(sc, 0.4, math.max(0.4, fitCeil))
    else
        sc = math.clamp(sc, 0.4, 2)
    end
    self._uiScale.Scale = sc
    self._uiScale:SetAttribute("UserScale", sc)
    if not fromSlider and self._scaleSlider then
        pcall(function() self._scaleSlider:Set(math.floor(sc / base * 100 + 0.5)) end)
    end
end

