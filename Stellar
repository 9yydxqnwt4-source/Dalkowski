function Library:CreateWindow(opts)
    opts = opts or {}
    cleanupOldGUIs()
    local _lsDisabled = not Library:GetLoadingScreenEnabled()
    if opts.LoadingScreen ~= false and not _lsDisabled then
        local loadHandle = Library:_showLoadingScreen({
            Name = opts.LoadingTitle or opts.Name or "Stellar",
            Subtitle = opts.LoadingSubtitle or opts.Subtitle or "",
            LogoText = opts.LogoText or string.sub(opts.Name or "S", 1, 1):upper(),
            LogoIcon = opts.LogoIcon or DEFAULT_LOGO,
        })
        local dur = opts.LoadingDuration or 5
        loadHandle:RampTo(0.9, dur)
        local preloadDone = false
        task.spawn(function()
            local assets, seen = {}, {}
            if Lucide and Lucide["48px"] then
                for _, d in pairs(Lucide["48px"]) do
                    local id = d and d[1]
                    if id then
                        local im = "rbxassetid://" .. tostring(id)
                        if not seen[im] then seen[im] = true; assets[#assets + 1] = im end
                    end
                end
            end
            if #assets > 0 then
                local cp = game:GetService("ContentProvider")
                pcall(function() cp:PreloadAsync(assets) end)
            end
            preloadDone = true
        end)
        local elapsed = 0
        while elapsed < dur or not preloadDone do
            elapsed = elapsed + task.wait()
        end
        loadHandle:Finish()
        task.wait(1)
    end
    if opts.KeySystem and opts.KeySettings then
        local done, passed = false, false
        Library:_promptKey(opts.KeySettings,
            function() passed = true; done = true end,
            function() done = true end)
        repeat task.wait() until done
        if not passed then return nil end
    end
    if opts.AutoExec then Library:AutoExec(opts.AutoExec) end
    if opts.Theme and THEMES[opts.Theme] then
        for k, v in pairs(THEMES[opts.Theme]) do COLOR[k] = v end
