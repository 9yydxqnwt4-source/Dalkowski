        Icon = "log-out",
        Callback = function() self:Destroy() end,
    })

    tab:CreateSection("Credits")
    tab:CreateButton({
        Name = "Dalkowski on discord",
        Description = "My Discord - click to copy",
        Icon = "at-sign",
        CopyValue = "Dalkowski",
    })
