    local iconSq = makeIconSquare(card, 28, opts.Icon)
    iconSq.AnchorPoint = Vector2.new(0, 0)
    iconSq.Position = UDim2.new(0, 13, 0, 11)
    new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 51, 0, 25),
        Size = UDim2.new(1, -64, 0, 18), BackgroundTransparency = 1,
        Text = opts.Name or "Input", Font = Enum.Font.GothamMedium, TextSize = 16,
        TextColor3 = COLOR.TextPrimary, TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 3,
    }, card)
    local frame = new("Frame", {
        AnchorPoint = Vector2.new(0, 1), Position = UDim2.new(0, 13, 1, -11),
        Size = UDim2.new(0.6, -13, 0, 24), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.04), BorderSizePixel = 0, ZIndex = 3,
        ClipsDescendants = true,
    }, card)
    corner(frame, 6)
    local fStroke = stroke(frame, Color3.fromRGB(255,255,255), wA(0.08), 1)
    local PADDING = 8
    local INNER_WIDTH = 2000
    local box = new("TextBox", {
        Size = UDim2.fromOffset(INNER_WIDTH, 24),
        Position = UDim2.fromOffset(PADDING, 0),
        BackgroundTransparency = 1, Text = value,
        PlaceholderText = opts.PlaceholderText or "",
        PlaceholderColor3 = Color3.fromRGB(140,140,140), Font = Enum.Font.Gotham,
        TextSize = 13, TextColor3 = COLOR.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false,
        ZIndex = 4,
    }, frame)
    local function syncScroll()
        local frameW = frame.AbsoluteSize.X
        if frameW <= 0 then return end
        local visibleW = frameW - PADDING * 2
        local cursorPos = box.CursorPosition
        if cursorPos < 0 then cursorPos = #box.Text + 1 end
        local upTo = box.Text:sub(1, math.max(0, cursorPos - 1))
        local cursorPx = game:GetService("TextService"):GetTextSize(
            upTo, 13, Enum.Font.Gotham, Vector2.new(INNER_WIDTH, 24)
        ).X
        local shift = 0
        if cursorPx > visibleW then shift = -(cursorPx - visibleW + 2) end
        box.Position = UDim2.fromOffset(PADDING + shift, 0)
    end
    box:GetPropertyChangedSignal("Text"):Connect(syncScroll)
    box:GetPropertyChangedSignal("CursorPosition"):Connect(syncScroll)
    box.Focused:Connect(function()
        tween(fStroke, 0.15, { Transparency = wA(0.2) })
        syncScroll()
    end)
    box.FocusLost:Connect(function()
        tween(fStroke, 0.15, { Transparency = wA(0.08) })
        value = box.Text
        updateFlag(win, flag, value); pcall(cb, value)
        if opts.RemoveTextAfterFocusLost then box.Text = "" end
        box.Position = UDim2.fromOffset(PADDING, 0)
    end)
    local element = {
        Type = "Input", Value = value,
        Set = function(self2, v)
            value = tostring(v); self2.Value = value; box.Text = value
            updateFlag(win, flag, value); pcall(cb, value)
        end,
        Get = function() return value end,
        GetLive = function() return box.Text end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

