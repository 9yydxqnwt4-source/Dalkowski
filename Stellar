function Library:SetLoaderUrl(url) self._loaderUrl = url end

function Library:AutoExec(url)
    if type(url) ~= "string" or url == "" then return false end
    self._autoExecUrl = url
    if not exec.queue_on_teleport then return false end
    local payload = string.format(
        "repeat task.wait() until game:IsLoaded() and game.Players.LocalPlayer\n"..
        "task.wait(0.5)\n"..
        "local ok,err=pcall(function() loadstring(game:HttpGet(%q))() end)\n"..
        "if not ok then warn('[Library] auto-exec failed: '..tostring(err)) end",
        url
    )
    local ok = pcall(exec.queue_on_teleport, payload)
    if not self._autoExecPersist then
        self._autoExecPersist = true
        task.spawn(function()
            local lp = Players.LocalPlayer
            if not lp then return end
            local ok2, ev = pcall(function() return lp.OnTeleport end)
            if ok2 and ev and typeof(ev) == "RBXScriptSignal" then
                ev:Connect(function() pcall(exec.queue_on_teleport, payload) end)
            end
            pcall(function()
                Players.PlayerRemoving:Connect(function(p)
                    if p == lp then pcall(exec.queue_on_teleport, payload) end
                end)
            end)
        end)
    end
    return ok
end

function Library:_armTeleportPersistence()
    if not exec.queue_on_teleport then return end
    local url = self._autoExecUrl or self._loaderUrl
    local payload = string.format(
        "repeat task.wait() until game:IsLoaded() and game.Players.LocalPlayer\n"..
        "local ok,err=pcall(function() loadstring(game:HttpGet(%q))() end)\n"..
        "if not ok then warn('[Library] reload failed: '..tostring(err)) end",
        url
    )
    pcall(exec.queue_on_teleport, payload)
end

