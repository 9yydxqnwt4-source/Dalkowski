    makeIconSquare(card, 28, opts.Icon)
    makeCardLabels(card, opts.Name or "Keybind", opts.Description, 155)
    local btn = new("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(82, 24), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.04), BorderSizePixel = 0,
        Text = "", AutoButtonColor = false, ZIndex = 3,
    }, card)
    corner(btn, 6)
    stroke(btn, Color3.fromRGB(255,255,255), wA(0.08), 1)
    local kLbl = new("TextLabel", {
        Size = UDim2.fromScale(1, 1), BackgroundTransparency = 1, Text = current,
        Font = Enum.Font.GothamMedium, TextSize = 13, TextColor3 = COLOR.TextPrimary, ZIndex = 4,
    }, btn)
    local listening = false
    btn.MouseButton1Click:Connect(function() listening = true; kLbl.Text = "..." end)
    UserInputService.InputBegan:Connect(function(input, processed)
        if listening and input.UserInputType == Enum.UserInputType.Keyboard then
            local key = input.KeyCode.Name
            current = key; kLbl.Text = key; listening = false
            updateFlag(win, flag, key)
            if callOnChange then pcall(cb, key) end
            return
        end
        if processed then return end
        if not listening and input.UserInputType == Enum.UserInputType.Keyboard and current ~= "None" then
            local ok, kc = pcall(function() return Enum.KeyCode[current] end)
            if ok and kc and input.KeyCode == kc then
                if hold then
                    pcall(cb, true)
                    local conn
                    conn = UserInputService.InputEnded:Connect(function(i2)
                        if i2.KeyCode == kc then
                            pcall(cb, false); conn:Disconnect()
                        end
                    end)
                else
                    if not callOnChange then pcall(cb) end
                end
            end
        end
    end)
    local element = {
        Type = "Keybind", Value = current,
        Set = function(self2, k)
            current = tostring(k); self2.Value = current; kLbl.Text = current
            updateFlag(win, flag, current)
        end,
        Get = function() return current end,
        Destroy = function() card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

function Tab:CreateLabel(text, icon, color, interval)
    local gradient, tooltip
    if type(text) == "table" then
        local opts = mergeDefaults(text, "Label")
        text = opts.Text; icon = opts.Icon; color = opts.Color or opts.TextColor
        interval = opts.RefreshInterval
        gradient = opts.TextGradient
        tooltip = opts.Tooltip
    end
    local resolver
    if type(text) == "function" then resolver = text; text = tostring(resolver()) end
    local card = makeCard(self, 40)
    if tooltip then bindTooltip(card, tooltip) end
    if icon then makeIconSquare(card, 22, icon) end
    local lbl = new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5),
        Position = UDim2.new(0, icon and 42 or 13, 0.5, 0),
        Size = UDim2.new(1, icon and -55 or -26, 1, 0),
        BackgroundTransparency = 1, Text = tostring(text or ""),
        Font = Enum.Font.GothamMedium, TextSize = 14,
        TextColor3 = color or Color3.fromRGB(255,255,255), TextTransparency = wA(0.92),
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 3,
    }, card)
    if gradient then applyTextGradient(lbl, gradient) end
    local destroyed = false
    if resolver and interval and interval > 0 then
        task.spawn(function()
            while not destroyed and card.Parent do
                task.wait(interval)
                if destroyed or not card.Parent then break end
                local ok, val = pcall(resolver)
                if ok then lbl.Text = tostring(val) end
            end
        end)
    end
    return {
        Type = "Label",
        Set = function(_, t, c)
            if type(t) == "function" then resolver = t; t = tostring(resolver()) end
            lbl.Text = tostring(t)
            if c then lbl.TextColor3 = c end
        end,
        Get = function() return lbl.Text end,
        Refresh = function()
            if resolver then
                local ok, val = pcall(resolver)
                if ok then lbl.Text = tostring(val) end
            end
        end,
        Destroy = function() destroyed = true; card:Destroy() end,
    }
end

