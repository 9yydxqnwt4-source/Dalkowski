        Font = Enum.Font.GothamMedium, TextSize = 16, TextColor3 = COLOR.TextPrimary,
        TextXAlignment = Enum.TextXAlignment.Left, TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 3,
    }, card)
    local descLbl
    if desc then
        descLbl = new("TextLabel", {
            AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 51, 0.5, 7),
            Size = UDim2.new(1, -rightReserve, 0, 15), BackgroundTransparency = 1, Text = desc,
