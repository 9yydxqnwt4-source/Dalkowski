    hit.MouseButton1Up:Connect(function() tween(card, 0.15, { BackgroundTransparency = wA(0.05) }) end)
    local function run()
        local ok, err = pcall(cb)
        if not ok then warn("[Library] Button error: " .. tostring(err)) end
        if copyValue then
            local val = type(copyValue) == "function" and copyValue() or copyValue
            if Library:CopyToClipboard(val) then
                Library:Notify({Title = "Copied", Image = "clipboard-check", Type = "success",
                    Content = (opts.Name or "Value") .. " copied to clipboard.", Duration = 2})
            else
                Library:Notify({Title = "Failed", Image = "x", Type = "error",
                    Content = "Your executor does not support clipboard.", Duration = 2})
            end
        end
    end
    hit.MouseButton1Click:Connect(function()
        if confirmMsg then
            Library:Confirm({
                Title = opts.ConfirmTitle or "Are you sure?",
                Content = confirmMsg, Icon = opts.ConfirmIcon or opts.Icon,
                YesText = opts.ConfirmYes or "Yes",
                NoText = opts.ConfirmNo or "Cancel",
                DangerYes = opts.ConfirmDanger,
            }, run)
        else
            run()
        end
    end)
    return {
        Type = "Button",
        Set = function(_, n) label.Text = n end,
        SetCallback = function(_, f) cb = f or function() end end,
        SetCopyValue = function(_, v) copyValue = v end,
        Fire = run,
        Destroy = function() card:Destroy() end,
    }
end

function Tab:CreateDropdown(opts)
    opts = mergeDefaults(opts, "Dropdown")
    local win = self._window
    local options = opts.Options or {}
    local multi = opts.MultipleOptions == true
    local current
    if multi then
        current = opts.CurrentOption or {}
        if type(current) == "string" then current = { current } end
    else
        current = opts.CurrentOption or options[1] or "None"
        if type(current) == "table" then current = current[1] or "None" end
    end
    local flag = opts.Flag
    local cb = opts.Callback or function() end
    local card = makeCard(self, 58)
    attachHover(card)
    bindTooltip(card, opts.Tooltip)
    makeIconSquare(card, 28, opts.Icon)
    makeCardLabels(card, opts.Name or "Dropdown", opts.Description)
    local trigger = new("TextButton", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -13, 0.5, 0),
        Size = UDim2.fromOffset(110, 24), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.04), BorderSizePixel = 0,
        Text = "", AutoButtonColor = false, ZIndex = 5,
    }, card)
    corner(trigger, 6)
    stroke(trigger, Color3.fromRGB(255,255,255), wA(0.08), 1)
    local function displayText()
        if multi then
            if #current == 0 then return "None"
            elseif #current == 1 then return current[1]
            else return "Various" end
        else
            return tostring(current)
        end
    end
    local valueLbl = new("TextLabel", {
        AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 10, 0.5, 0),
        Size = UDim2.new(1, -28, 1, 0), BackgroundTransparency = 1,
        Text = displayText(), Font = Enum.Font.GothamMedium, TextSize = 13,
        TextColor3 = COLOR.TextPrimary, TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 6,
    }, trigger)
    local chevHolder = new("Frame", {
        AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -7, 0.5, 0),
        Size = UDim2.fromOffset(12, 12), BackgroundTransparency = 1, ZIndex = 6,
    }, trigger)
    applyIcon(chevHolder, "chevron-down", 12, 0.6)
    local menu = new("Frame", {
        Visible = false, AnchorPoint = Vector2.new(1, 0),
        Position = UDim2.new(0, 0, 0, 0), Size = UDim2.fromOffset(160, 0),
        AutomaticSize = Enum.AutomaticSize.Y, BackgroundColor3 = COLOR.BgLight,
        BorderSizePixel = 0, ZIndex = 50,
    }, win.Gui)
    corner(menu, 10)
    stroke(menu, Color3.fromRGB(255,255,255), wA(0.12), 1)
    pad(menu, 5, 5, 5, 5)
    listV(menu, 2)
    local optionButtons = {}
    local function isSelected(opt)
        if multi then return table.find(current, opt) ~= nil
        else return opt == current end
    end
    local function rebuildMenu()
        for _, b in ipairs(optionButtons) do b:Destroy() end
        table.clear(optionButtons)
        for i, opt in ipairs(options) do
            local sel = isSelected(opt)
            local row = new("TextButton", {
                Size = UDim2.new(1, 0, 0, 28), BackgroundColor3 = sel and COLOR.Accent or Color3.fromRGB(255,255,255),
                BackgroundTransparency = sel and wA(0.16) or 1,
                BorderSizePixel = 0, Text = "", AutoButtonColor = false,
                LayoutOrder = i, ZIndex = 51,
            }, menu)
            corner(row, 6)
            new("TextLabel", {
                AnchorPoint = Vector2.new(0, 0.5), Position = UDim2.new(0, 11, 0.5, 0),
                Size = UDim2.new(1, -34, 1, 0), BackgroundTransparency = 1,
                Text = opt, Font = Enum.Font.GothamMedium, TextSize = 13,
                TextColor3 = Color3.fromRGB(255,255,255),
                TextTransparency = sel and 0 or wA(0.58),
                TextXAlignment = Enum.TextXAlignment.Left,
                TextTruncate = Enum.TextTruncate.AtEnd, ZIndex = 52,
            }, row)
            if sel then
                local checkHolder = new("Frame", {
                    AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -9, 0.5, 0),
                    Size = UDim2.fromOffset(14, 14), BackgroundTransparency = 1, ZIndex = 52,
                }, row)
                local chkImg = applyIcon(checkHolder, "check", 14, 1)
                if chkImg then chkImg.ImageColor3 = COLOR.Accent end
            end
            row.MouseEnter:Connect(function()
                if not isSelected(opt) then tween(row, 0.1, { BackgroundTransparency = wA(0.07) }) end
            end)
            row.MouseLeave:Connect(function()
                tween(row, 0.1, { BackgroundTransparency = isSelected(opt) and wA(0.16) or 1 })
            end)
            row.MouseButton1Click:Connect(function()
                if multi then
                    local idx = table.find(current, opt)
                    if idx then table.remove(current, idx) else table.insert(current, opt) end
                    valueLbl.Text = displayText()
                    updateFlag(win, flag, current); pcall(cb, current)
                    rebuildMenu()
                else
                    current = opt; valueLbl.Text = opt
                    updateFlag(win, flag, opt); pcall(cb, opt)
                    rebuildMenu(); menu.Visible = false
                end
            end)
            table.insert(optionButtons, row)
        end
    end
    rebuildMenu()
    local function positionMenu()
        local sc = (win._uiScale and win._uiScale.Scale) or 1
        if sc <= 0 then sc = 1 end
        local g = win.Gui and win.Gui.AbsolutePosition or Vector2.new(0, 0)
        local p = trigger.AbsolutePosition
        local s = trigger.AbsoluteSize
        menu.Position = UDim2.fromOffset((p.X + s.X - g.X) / sc, (p.Y + s.Y + 4 - g.Y) / sc)
    end
    trigger.MouseButton1Click:Connect(function()
        if menu.Visible then menu.Visible = false
        else positionMenu(); menu.Visible = true end
    end)
    UserInputService.InputBegan:Connect(function(input)
        if not menu.Visible then return end
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local mp = input.Position
        local mPos, mSize = menu.AbsolutePosition, menu.AbsoluteSize
        local tPos, tSize = trigger.AbsolutePosition, trigger.AbsoluteSize
        local inMenu = mp.X >= mPos.X and mp.X <= mPos.X + mSize.X and mp.Y >= mPos.Y and mp.Y <= mPos.Y + mSize.Y
        local inTrig = mp.X >= tPos.X and mp.X <= tPos.X + tSize.X and mp.Y >= tPos.Y and mp.Y <= tPos.Y + tSize.Y
        if not inMenu and not inTrig then menu.Visible = false end
    end)
    local element = {
        Type = "Dropdown", Value = current,
        Set = function(self2, opt)
            if multi then
                if type(opt) == "string" then opt = { opt } end
                current = opt or {}
            else
                if type(opt) == "table" then opt = opt[1] end
                current = opt
            end
            valueLbl.Text = displayText(); self2.Value = current
            updateFlag(win, flag, current); rebuildMenu(); pcall(cb, current)
        end,
        Get = function() return current end,
        Refresh = function(_, newOpts)
            options = newOpts
            if multi then
                local kept = {}
                for _, o in ipairs(current) do if table.find(options, o) then table.insert(kept, o) end end
                current = kept
            else
                if not table.find(options, current) then current = options[1] or "None" end
            end
            valueLbl.Text = displayText()
            rebuildMenu()
        end,
        Destroy = function() card:Destroy(); menu:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end

function Tab:CreateInput(opts)
