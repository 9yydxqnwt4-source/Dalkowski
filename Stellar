    local svBlack = new("Frame", { Size = UDim2.fromScale(1,1), BackgroundColor3 = Color3.new(0,0,0),
        BorderSizePixel = 0, ZIndex = 53 }, sv)
    corner(svBlack, 7)
    new("UIGradient", { Parent = svBlack, Rotation = 90,
        Transparency = NumberSequence.new({ NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0) }),
    })
    local svCursor = new("Frame", {
        Size = UDim2.fromOffset(10, 10), AnchorPoint = Vector2.new(0.5, 0.5),
        BackgroundTransparency = 1, ZIndex = 54,
    }, sv)
    stroke(svCursor, Color3.new(1,1,1), 0, 2)
    corner(svCursor, 999)

    local hue = new("Frame", {
        Position = UDim2.fromOffset(162, 0), Size = UDim2.fromOffset(102, 14),
        BackgroundColor3 = Color3.new(1,1,1), BorderSizePixel = 0, ZIndex = 51,
    }, panel)
    corner(hue, 999)
    new("UIGradient", { Parent = hue,
        Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0.00, Color3.fromHSV(0.00, 1, 1)),
            ColorSequenceKeypoint.new(0.16, Color3.fromHSV(0.16, 1, 1)),
            ColorSequenceKeypoint.new(0.33, Color3.fromHSV(0.33, 1, 1)),
            ColorSequenceKeypoint.new(0.50, Color3.fromHSV(0.50, 1, 1)),
            ColorSequenceKeypoint.new(0.66, Color3.fromHSV(0.66, 1, 1)),
            ColorSequenceKeypoint.new(0.83, Color3.fromHSV(0.83, 1, 1)),
            ColorSequenceKeypoint.new(1.00, Color3.fromHSV(1.00, 1, 1)),
        }),
    })
    local hueCursor = new("Frame", {
        AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0, 0, 0.5, 0),
        Size = UDim2.fromOffset(3, 18), BackgroundColor3 = Color3.new(1,1,1),
        BorderSizePixel = 0, ZIndex = 52,
    }, hue)
    corner(hueCursor, 2)

    local function miniInput(y, ph)
        local box = new("Frame", {
            Position = UDim2.fromOffset(162, y), Size = UDim2.fromOffset(102, 26),
            BackgroundColor3 = Color3.fromRGB(255,255,255), BackgroundTransparency = wA(0.05),
            BorderSizePixel = 0, ZIndex = 51, ClipsDescendants = true,
        }, panel)
        corner(box, 6)
        local bs = stroke(box, Color3.fromRGB(255,255,255), wA(0.08), 1)
        local tb = new("TextBox", {
            Position = UDim2.fromOffset(8, 0), Size = UDim2.new(1, -16, 1, 0),
            BackgroundTransparency = 1, Text = "", PlaceholderText = ph,
            PlaceholderColor3 = Color3.fromRGB(130,130,130), Font = Enum.Font.GothamMedium,
            TextSize = 12, TextColor3 = COLOR.TextPrimary,
            TextXAlignment = Enum.TextXAlignment.Left, ClearTextOnFocus = false, ZIndex = 52,
        }, box)
        tb.Focused:Connect(function() tween(bs, 0.15, { Color = COLOR.Accent, Transparency = wA(0.4) }) end)
        tb.FocusLost:Connect(function() tween(bs, 0.15, { Color = Color3.fromRGB(255,255,255), Transparency = wA(0.08) }) end)
        return tb
    end
    local hexBox = miniInput(28, "#RRGGBB")
    local rgbBox = miniInput(62, "R, G, B")

    local h, s, v = startColor:ToHSV()
    local editing = false
    local function repaint()
        sv.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
        svCursor.Position = UDim2.new(s, 0, 1 - v, 0)
        hueCursor.Position = UDim2.new(h, 0, 0.5, 0)
        local c = Color3.fromHSV(h, s, v)
        swatch.BackgroundColor3 = c
        if not editing then
            local r, g, b = math.floor(c.R*255+0.5), math.floor(c.G*255+0.5), math.floor(c.B*255+0.5)
            rgbBox.Text = string.format("%d, %d, %d", r, g, b)
            hexBox.Text = string.format("#%02X%02X%02X", r, g, b)
        end
        return c
    end
    repaint()

    local function applyColor(c)
        h, s, v = c:ToHSV()
        repaint()
        if flag then win.Flags[flag] = c end; pcall(cb, c)
    end
    hexBox.Focused:Connect(function() editing = true end)
    hexBox.FocusLost:Connect(function()
        editing = false
        local hx = hexBox.Text:gsub("#", ""):gsub("%s", "")
        if #hx == 6 and hx:match("^%x+$") then
            local r = tonumber(hx:sub(1,2), 16)
            local g = tonumber(hx:sub(3,4), 16)
            local b = tonumber(hx:sub(5,6), 16)
            if r and g and b then applyColor(Color3.fromRGB(r, g, b)); return end
        end
        repaint()
    end)
    rgbBox.Focused:Connect(function() editing = true end)
    rgbBox.FocusLost:Connect(function()
        editing = false
        local r, g, b = rgbBox.Text:match("(%d+)%s*,%s*(%d+)%s*,%s*(%d+)")
        r, g, b = tonumber(r), tonumber(g), tonumber(b)
        if r and g and b then
            applyColor(Color3.fromRGB(math.clamp(r,0,255), math.clamp(g,0,255), math.clamp(b,0,255)))
            return
        end
        repaint()
    end)

    local open = false
    local function positionPanel()
        local sc = (win._uiScale and win._uiScale.Scale) or 1
        if sc <= 0 then sc = 1 end
        local g = win.Gui and win.Gui.AbsolutePosition or Vector2.new(0, 0)
        local cp = card.AbsolutePosition
        local cs = card.AbsoluteSize
        panel.Position = UDim2.fromOffset((cp.X + cs.X - g.X) / sc, (cp.Y + cs.Y - g.Y + 6) / sc)
    end
    local function setOpen(o)
        open = o
        if open then positionPanel() end
        panel.Visible = open
        tween(chevHolder, 0.25, { Rotation = open and 180 or 0 })
    end
    local function toggleOpen() setOpen(not open) end
    swatch.MouseButton1Click:Connect(toggleOpen)
    local cardHit = new("TextButton", {
        Position = UDim2.fromOffset(0, 0), Size = UDim2.new(1, 0, 1, 0),
        BackgroundTransparency = 1, Text = "", AutoButtonColor = false, ZIndex = 4,
    }, card)
    cardHit.MouseButton1Click:Connect(toggleOpen)

    local function svHit(p)
        local pos, size = sv.AbsolutePosition, sv.AbsoluteSize
        s = math.clamp((p.X - pos.X) / size.X, 0, 1)
        v = math.clamp(1 - (p.Y - pos.Y) / size.Y, 0, 1)
        local c = repaint()
        if flag then win.Flags[flag] = c end; pcall(cb, c)
    end
    local function hueHit(p)
        local pos, size = hue.AbsolutePosition, hue.AbsoluteSize
        h = math.clamp((p.X - pos.X) / size.X, 0, 1)
        local c = repaint()
        if flag then win.Flags[flag] = c end; pcall(cb, c)
    end
    local function bindDrag(zone, fn)
        local dragging = false
        local b = new("TextButton", { Size = UDim2.fromScale(1,1), BackgroundTransparency = 1,
            Text = "", AutoButtonColor = false, ZIndex = 55 }, zone)
        b.InputBegan:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
                and input.UserInputType ~= Enum.UserInputType.Touch then return end
            dragging = true
            fn(input.Position)
        end)
        b.InputEnded:Connect(function(input)
            if input.UserInputType ~= Enum.UserInputType.MouseButton1
                and input.UserInputType ~= Enum.UserInputType.Touch then return end
            if not dragging then return end
            dragging = false
        end)
        UserInputService.InputChanged:Connect(function(input)
            if not dragging then return end
            if input.UserInputType == Enum.UserInputType.MouseMovement
                or input.UserInputType == Enum.UserInputType.Touch then
                fn(input.Position)
            end
        end)
    end
    bindDrag(sv, svHit)
    bindDrag(hue, hueHit)

    UserInputService.InputBegan:Connect(function(input)
        if not open then return end
        if input.UserInputType ~= Enum.UserInputType.MouseButton1 and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local mp = input.Position
        local function inside(o)
            local op, os2 = o.AbsolutePosition, o.AbsoluteSize
            return mp.X >= op.X and mp.X <= op.X + os2.X and mp.Y >= op.Y and mp.Y <= op.Y + os2.Y
        end
        if not inside(panel) and not inside(card) then setOpen(false) end
    end)
    if win.Window then
        win.Window:GetPropertyChangedSignal("Visible"):Connect(function()
            if not win.Window.Visible then setOpen(false) end
        end)
    end

    local element = {
        Type = "ColorPicker", Value = startColor,
        Set = function(self2, c)
            if typeof(c) == "Color3" then
                h, s, v = c:ToHSV()
                self2.Value = repaint()
                if flag then win.Flags[flag] = self2.Value end; pcall(cb, self2.Value)
            end
        end,
        Get = function() return Color3.fromHSV(h, s, v) end,
        Destroy = function() if panel then panel:Destroy() end card:Destroy() end,
    }
    registerFlag(win, flag, element)
    return element
end
function Window:SetStatus(opts)
    opts = opts or {}
    local accent = opts.Accent or COLOR.Accent
    if self._statusBar then self._statusBar:Destroy() end
    if self._statusDivL then self._statusDivL:Destroy() end
    if self._statusDivR then self._statusDivR:Destroy() end
    self._statusReservedHeight = 0
    local row = new("Frame", {
        Name = "StatusBar",
        AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0.5, 0, 0.5, 0),
        AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.fromOffset(0, 34),
        BackgroundColor3 = accent, BackgroundTransparency = 0.9, BorderSizePixel = 0, ZIndex = 3,
    }, self.Titlebar)
    corner(row, 8)
    stroke(row, accent, 0.75, 1)
    new("UIPadding", { PaddingLeft = UDim.new(0, 16), PaddingRight = UDim.new(0, 16) }, row)
    new("UISizeConstraint", { MinSize = Vector2.new(320, 34) }, row)
    listH(row, 9, Enum.VerticalAlignment.Center, Enum.HorizontalAlignment.Center)
    self._statusBar = row
    local function statusDiv(sign)
        return new("Frame", {
            AnchorPoint = Vector2.new(0.5, 0.5),
            Position = UDim2.new(0.5, sign * 210, 0.5, 0),
            Size = UDim2.fromOffset(1, 22),
            BackgroundColor3 = SEP_COLOR, BackgroundTransparency = 0.45,
            BorderSizePixel = 0, ZIndex = 3,
        }, self.Titlebar)
    end
    self._statusDivL = statusDiv(-1)
    self._statusDivR = statusDiv(1)
    local function placeDivs()
        local scale = (self._uiScale and self._uiScale.Scale) or 1
        local half = (row.AbsoluteSize.X / scale) / 2 + 16
        if self._statusDivL then self._statusDivL.Position = UDim2.new(0.5, -half, 0.5, 0) end
        if self._statusDivR then self._statusDivR.Position = UDim2.new(0.5, half, 0.5, 0) end
    end
    row:GetPropertyChangedSignal("AbsoluteSize"):Connect(placeDivs)
    task.defer(placeDivs)
    local dot = new("Frame", {
        Size = UDim2.fromOffset(8, 8), BackgroundColor3 = Color3.fromRGB(74, 222, 128),
        BorderSizePixel = 0, LayoutOrder = 1, ZIndex = 4,
    }, row)
    corner(dot, 4)
    local labelLbl = new("TextLabel", {
        AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.fromOffset(0, 16), BackgroundTransparency = 1,
        Text = opts.Label or "Active", Font = Enum.Font.GothamMedium, TextSize = 12,
        TextColor3 = opts.LabelColor or Color3.fromRGB(74, 222, 128), TextXAlignment = Enum.TextXAlignment.Left,
        TextYAlignment = Enum.TextYAlignment.Center, LayoutOrder = 2, ZIndex = 4,
    }, row)
    if opts.LabelGradient then applyTextGradient(labelLbl, opts.LabelGradient) end
    local hasGame = (opts.Game ~= nil and opts.Game ~= "")
    local midSep = new("Frame", {
        Size = UDim2.fromOffset(1, 16), BackgroundColor3 = Color3.fromRGB(255,255,255),
        BackgroundTransparency = wA(0.18), BorderSizePixel = 0, LayoutOrder = 3, ZIndex = 4, Visible = hasGame,
    }, row)
    local rightLbl = new("TextButton", {
        AutomaticSize = Enum.AutomaticSize.X, Size = UDim2.fromOffset(0, 16),
        BackgroundTransparency = 1, AutoButtonColor = false, Visible = hasGame,
        Text = opts.Game or "", Font = Enum.Font.GothamMedium, TextSize = 12,
        TextColor3 = COLOR.TextPrimary, TextTransparency = wA(0.85),
        TextXAlignment = Enum.TextXAlignment.Left, TextYAlignment = Enum.TextYAlignment.Center,
        LayoutOrder = 4, ZIndex = 4,
    }, row)
    local gameGradient = opts.GameGradient and applyTextGradient(rightLbl, opts.GameGradient) or nil
    if gameGradient and opts.AnimatedGradient then
        rightLbl.TextTransparency = 0
        task.spawn(function()
            local TweenService = game:GetService("TweenService")
            local info = TweenInfo.new(2.4, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true, 0)
            while gameGradient and gameGradient.Parent do
                gameGradient.Offset = Vector2.new(-1, 0)
                local tw = TweenService:Create(gameGradient, info, { Offset = Vector2.new(1, 0) })
                tw:Play()
                task.wait(4.8)
            end
        end)
    end
    if not opts.Game then
        task.spawn(function()
            local ok, info = pcall(function()
                return game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId)
            end)
            if ok and info and info.Name and rightLbl.Parent then
                rightLbl.Text = info.Name
                rightLbl.Visible = true
                if midSep then midSep.Visible = true end
            end
        end)
    end
    return {
        SetLabel = function(_, t) labelLbl.Text = t end,
        SetGame = function(_, t) rightLbl.Text = tostring(t) end,
        SetAccent = function(_, c)
            row.BackgroundColor3 = c
            local st = row:FindFirstChildOfClass("UIStroke")
            if st then st.Color = c end
            dot.BackgroundColor3 = c
        end,
        Destroy = function()
            row:Destroy()
            self._statusReservedHeight = 0
            self._statusBar = nil
        end,
    }
end

function Window:SaveConfig()
    if not self.Config.Enabled then return end
    if self._loadingConfig then return end
    safeMkdir(self.Config.FolderName)
    safeMkdir(self.Config.FolderName .. "/Configs")
    local data = {}
    for flag, value in pairs(self.Flags) do
        if typeof(value) == "Color3" then
            data[flag] = { _t = "Color3", r = value.R, g = value.G, b = value.B }
        else
            data[flag] = value
        end
    end
    local path = self.Config.FolderName .. "/Configs/" .. self.Config.FileName .. ".json"
    safeWrite(path, HttpService:JSONEncode(data))
end

function Window:_preloadConfig()
    if not self.Config.Enabled then return end
    local autoloadPath = self.Config.FolderName .. "/autoload.txt"
    local autoload = safeRead(autoloadPath)
    if not (autoload and autoload ~= "") then return end
    self.Config.FileName = autoload
    local path = self.Config.FolderName .. "/Configs/" .. self.Config.FileName .. ".json"
    local raw = safeRead(path)
    if not raw then return end
    local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok or type(data) ~= "table" then return end
    self._pendingConfigData = data
end

function Window:LoadConfig()
    if not self.Config.Enabled then return end
    local path = self.Config.FolderName .. "/Configs/" .. self.Config.FileName .. ".json"
    local raw = safeRead(path)
    if not raw then return end
    local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok or type(data) ~= "table" then return end
    self._pendingConfigData = data
    self._loadingConfig = true
    for flag, value in pairs(data) do
        local element = Library.Flags[flag]
        if element and element.Set then
            if type(value) == "table" and value._t == "Color3" then
                pcall(function() element:Set(Color3.new(value.r, value.g, value.b)) end)
            else
                pcall(function() element:Set(value) end)
            end
        end
    end
    self._loadingConfig = false
end

UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    if input.UserInputType ~= Enum.UserInputType.Keyboard then return end
    if input.KeyCode ~= Library.ToggleKey then return end
    local anyVisible = false
    for _, w in ipairs(Library._windows) do
        if not w._destroyed and w:IsVisible() then anyVisible = true; break end
    end
    Library:SetVisibility(not anyVisible)
end)

return Library
