        tab:CreateButton({
            Name = (self.Discord:gsub("^https?://", "")),
            Description = "Invite link - click to copy",
            Icon = "message-circle",
            CopyValue = self.Discord,
        })
    end

    if self.Config.Enabled then
        tab._fixedCol = 2
        local cfg = self.Config
        local configsPath = cfg.FolderName .. "/Configs"
        local autoloadFile = cfg.FolderName .. "/autoload.txt"

        local function listConfigs()
            local list = {}
            if exec.isfolder and exec.isfolder(configsPath) and exec.listfiles then
                local ok, files = pcall(exec.listfiles, configsPath)
                if ok and files then
                    for _, f in ipairs(files) do
                        local n = string.match(f, "([^/\\]+)%.json$")
                        if n then table.insert(list, n) end
                    end
                end
            end
            table.sort(list)
            return list
        end
        local function readAutoload()
            local s = safeRead(autoloadFile)
            if s and s ~= "" then return s end
            return nil
        end

        tab:CreateSection("Configuration")
        local typedName = ""
        local nameInput = tab:CreateInput({
            Name = "Config name", Icon = "file-text",
            PlaceholderText = "MyConfig", CurrentValue = "",
            Callback = function(v) typedName = v end,
        })
        local list = listConfigs()
        local selected = list[1] or "---"
        local dropdown
        local function readName()
            local live = nameInput and nameInput.GetLive and nameInput:GetLive() or nil
            local name = (live and live ~= "") and live or typedName or ""
            name = name:gsub("^%s+", ""):gsub("%s+$", "")
            return name
        end
        tab:CreateButton({
            Name = "Create config", Icon = "plus",
            Callback = function()
                local name = readName()
                if name == "" then
                    Library:Notify({Title = "Empty", Type = "warning", Image = "info", Content = "Enter a name first.", Duration = 2})
                    return
                end
                if name:find("[\\/:*?\"<>|]") then
                    Library:Notify({Title = "Bad name", Type = "warning", Image = "x",
                        Content = "Avoid \\ / : * ? \" < > |", Duration = 3})
                    return
                end
                local orig = cfg.FileName
                cfg.FileName = name
                self:SaveConfig()
                cfg.FileName = orig
                Library:Notify({Title = "Created", Type = "success", Image = "check", Content = name, Duration = 2})
                list = listConfigs()
                if dropdown then
                    dropdown:Refresh(#list > 0 and list or {"---"})
                    if dropdown.Set then pcall(function() dropdown:Set(name) end) end
                end
                selected = name
            end,
        })
        tab:CreateDivider()
        dropdown = tab:CreateDropdown({
            Name = "Config list", Icon = "list",
            Options = #list > 0 and list or {"---"},
            CurrentOption = list[1] or "---",
            Callback = function(v) selected = v end,
        })
        self._refreshConfigList = function()
            list = listConfigs()
            if dropdown then dropdown:Refresh(#list > 0 and list or {"---"}) end
        end
        tab:CreateButton({
            Name = "Load config", Icon = "download",
            Callback = function()
                if selected == "---" or selected == "" then return end
                cfg.FileName = selected
                self:LoadConfig()
                Library:Notify({Title = "Loaded", Type = "success", Image = "check", Content = selected, Duration = 2})
            end,
        })
        tab:CreateButton({
            Name = "Delete config", Icon = "trash-2",
            ConfirmMessage = "Delete the selected config?", ConfirmDanger = true, ConfirmYes = "Delete",
            Callback = function()
                if selected == "---" or selected == "" then return end
                if exec.delfile then pcall(exec.delfile, configsPath .. "/" .. selected .. ".json") end
                Library:Notify({Title = "Deleted", Type = "error", Image = "trash-2", Content = selected, Duration = 2})
                list = listConfigs()
                if dropdown then dropdown:Refresh(#list > 0 and list or {"---"}) end
                selected = list[1] or "---"
            end,
        })
        tab:CreateButton({
            Name = "Refresh list", Icon = "refresh-cw",
            Callback = function()
                list = listConfigs()
                if dropdown then dropdown:Refresh(#list > 0 and list or {"---"}) end
            end,
        })
        local autoloadLabel
        local function renderAutoload()
            local cur = readAutoload()
            local txt = "Autoload: " .. (cur or "none")
            if autoloadLabel then autoloadLabel:Set(txt) end
        end
        tab:CreateButton({
            Name = "Set as autoload", Icon = "pin",
            Callback = function()
                if selected == "---" or selected == "" then return end
                safeWrite(autoloadFile, selected)
                renderAutoload()
                Library:Notify({Title = "Autoload set", Type = "success", Image = "check", Content = selected, Duration = 2})
            end,
        })
        tab:CreateButton({
            Name = "Reset autoload", Icon = "x",
            Callback = function()
                if exec.delfile then pcall(exec.delfile, autoloadFile) end
                renderAutoload()
                Library:Notify({Title = "Autoload reset", Type = "info", Image = "info", Duration = 2})
            end,
        })
        autoloadLabel = tab:CreateLabel("Autoload: " .. (readAutoload() or "none"))

        tab:CreateDivider()
        tab:CreateLabel("Deletes all saved configs. Next launch starts fresh.")
        tab:CreateButton({
            Name = "Reset Script (Fresh Start)", Icon = "trash-2",
            ConfirmMessage = "Delete ALL saved configs and the autoload pointer? Cannot be undone.",
            ConfirmDanger = true, ConfirmYes = "Wipe",
            Callback = function()

                self.Config.Enabled = false
                if exec.delfile then

                    pcall(exec.delfile, autoloadFile)

                    if exec.isfolder and exec.isfolder(configsPath) and exec.listfiles then
                        local ok, files = pcall(exec.listfiles, configsPath)
                        if ok and files then
                            for _, f in ipairs(files) do
                                pcall(exec.delfile, f)
                            end
                        end
                    end

                    pcall(exec.delfile, cfg.FolderName .. "/library_cache.lua")
                    pcall(exec.delfile, cfg.FolderName .. "/library_ts.txt")
                end
                list = listConfigs()
                if dropdown then dropdown:Refresh(#list > 0 and list or {"---"}) end
                renderAutoload()
                Library:Notify({
                    Title = "Reset complete", Type = "success", Image = "check",
                    Content = "Re-execute the script for a fresh start.",
                    Duration = 6,
                })
            end,
        })
    end
end

function Window:GetSettingsTab()
    return self._settingsTab
end

function Window:_openSettings()
    if not self._settingsTab then return end
    if self._refreshConfigList then pcall(self._refreshConfigList) end
    self:_closeSearch()
    self._previousTab = self.ActiveTab
    self:_showTab(self._settingsTab, "Settings")
end

function Window:_closeSettings()
    if self._previousTab then
        self:SetActiveTab(self._previousTab)
        self._previousTab = nil
    end
end

function Window:_showTab(tab, title)
    for _, t in ipairs(self.Tabs) do
        t.Panel.Visible = false
        tween(t.Button, 0.2, { BackgroundColor3 = Color3.fromRGB(255,255,255), BackgroundTransparency = wA(0.07) })
        tween(t.BtnStroke, 0.2, { Color = Color3.fromRGB(255,255,255), Transparency = wA(0.04) })
        if t.BtnIcon then
            if t.BtnIcon:IsA("ImageLabel") then tween(t.BtnIcon, 0.2, { ImageColor3 = COLOR.TextPrimary, ImageTransparency = wA(0.5) })
            else tween(t.BtnIcon, 0.2, { TextColor3 = COLOR.TextPrimary, TextTransparency = wA(0.5) }) end
        end
        tween(t.BtnLabel, 0.2, { TextColor3 = COLOR.TextPrimary, TextTransparency = wA(0.5) })
    end
    if self._settingsTab then self._settingsTab.Panel.Visible = false end
    tab.Panel.Visible = true
    local newIdx = table.find(self.Tabs, tab) or 1
    local dir = (newIdx >= (self._lastTabIndex or newIdx)) and 1 or -1
    self._lastTabIndex = newIdx
    tab.Panel.Position = UDim2.fromOffset(dir * 40, 0)
    tween(tab.Panel, 0.34, { Position = UDim2.fromOffset(0, 0) }, Enum.EasingStyle.Quint)
    if tab.Button then
        tween(tab.Button, 0.2, { BackgroundColor3 = COLOR.Accent, BackgroundTransparency = 0.12 })
        tween(tab.BtnStroke, 0.2, { Color = COLOR.Accent, Transparency = 0.5 })
        if tab.BtnIcon then
            if tab.BtnIcon:IsA("ImageLabel") then tween(tab.BtnIcon, 0.2, { ImageColor3 = Color3.fromRGB(255,255,255), ImageTransparency = 0 })
            else tween(tab.BtnIcon, 0.2, { TextColor3 = Color3.fromRGB(255,255,255), TextTransparency = 0 }) end
        end
        tween(tab.BtnLabel, 0.2, { TextColor3 = Color3.fromRGB(255,255,255), TextTransparency = 0 })
    end
    if self.SectionTitle then
        self.SectionTitle.TextTransparency = 1
        self.SectionTitle.Text = title or tab._name
        tween(self.SectionTitle, 0.25, { TextTransparency = 0 })
    end
end

