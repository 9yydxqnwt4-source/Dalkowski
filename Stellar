local LIB_SIG = "__StellarLibGUI_v2"

local function tagGui(gui)
    pcall(function() gui:SetAttribute(LIB_SIG, true) end)
end

local function cleanupOldGUIs()
    local containers = {}
    if exec.gethui then
        local ok, h = pcall(exec.gethui)
        if ok and h then table.insert(containers, h) end
    end
    table.insert(containers, CoreGui)
    pcall(function()
        local pg = LocalPlayer and LocalPlayer:FindFirstChild("PlayerGui")
        if pg then table.insert(containers, pg) end
    end)
    for _, c in ipairs(containers) do
        pcall(function()
            for _, child in ipairs(c:GetChildren()) do
                if child:IsA("ScreenGui") and child:GetAttribute(LIB_SIG) then
                    pcall(function() child:Destroy() end)
                end
            end
        end)
    end
end

local function safeParent(gui)
    tagGui(gui)
    if exec.gethui then
        local ok = pcall(function() gui.Parent = exec.gethui() end)
        if ok and gui.Parent then return end
    end
    if exec.protect_gui then pcall(exec.protect_gui, gui) end
    local ok = pcall(function() gui.Parent = CoreGui end)
    if ok and gui.Parent then return end
    gui.Parent = LocalPlayer:WaitForChild("PlayerGui")
end

