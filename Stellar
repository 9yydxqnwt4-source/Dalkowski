        end
        local fadeTw = tween(backdrop, D, { BackgroundTransparency = 1 }, ES, ED)
        fadeTw.Completed:Wait()
        if gui then gui:Destroy() end
    end
    handle.Gui = gui
    handle:SetProgress(0.15)
    return handle
end

